# Supabase — URL e chaves do projeto (Supabase Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role (server-side apenas: webhooks, scripts admin; NUNCA no client)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — billing SaaS (cobrança da mensalidade do lojista)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Gateway de pedidos da loja (Mercado Pago OU Pagar.me)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
# ou
PAGARME_API_KEY=
PAGARME_WEBHOOK_SECRET=
